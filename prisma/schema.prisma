generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Item {
  id             String   @id @default(cuid())
  name           String
  typeId         Int?     @unique
  isRawMaterial  Boolean  @default(false)
  isFound        Boolean  @default(false)
  isFinalProduct Boolean  @default(false)
  isAsteroid     Boolean  @default(false)
  volume         Float    @default(0)
  description    String?
  mass           Float?
  radius         Float?
  portionSize    Int?
  groupName      String?
  groupId        Int?
  categoryName   String?
  categoryId     Int?
  iconUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  blueprints           Blueprint[]
  usedAsInput          BlueprintInput[]
  packItems            PackItem[]
  decompositions       Decomposition[]
  decompositionOutputs DecompositionOutput[]
  asteroidTypes        ItemAsteroidType[]
}

model Blueprint {
  id           String   @id @default(cuid())
  blueprintId  Int?
  outputItemId String
  factory      String   @default("")
  outputQty    Int      @default(1)
  runTime      Int      @default(0)
  maxInputRuns Int?
  maxOutputRuns Int?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  outputItem Item             @relation(fields: [outputItemId], references: [id], onDelete: Cascade)
  inputs     BlueprintInput[]

  @@unique([outputItemId, factory])
}

model BlueprintInput {
  id          String @id @default(cuid())
  blueprintId String
  itemId      String
  quantity    Int

  blueprint Blueprint @relation(fields: [blueprintId], references: [id], onDelete: Cascade)
  item      Item      @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([blueprintId, itemId])
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  password      String?
  walletAddress String?  @unique
  role          String   @default("USER")
  ssuAddress    String?
  createdAt     DateTime @default(now())

  packs  Pack[]
}

model Settings {
  id               String  @id @default("global")
  registrationOpen Boolean @default(true)
}

// 1 unit of sourceItem → multiple output materials (reprocessing/decomposition)
// Multiple decompositions per sourceItem are allowed (one per refinery)
model Decomposition {
  id           String   @id @default(cuid())
  blueprintId  Int?
  sourceItemId String
  refinery     String   @default("")
  inputQty     Int      @default(1)
  runTime      Int      @default(0)
  maxInputRuns Int?
  maxOutputRuns Int?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sourceItem Item                  @relation(fields: [sourceItemId], references: [id], onDelete: Cascade)
  outputs    DecompositionOutput[]

  @@unique([sourceItemId, refinery, blueprintId])
}

model DecompositionOutput {
  id              String @id @default(cuid())
  decompositionId String
  itemId          String
  quantity        Int

  decomposition Decomposition @relation(fields: [decompositionId], references: [id], onDelete: Cascade)
  item          Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([decompositionId, itemId])
}

model AsteroidType {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     ItemAsteroidType[]
  locations AsteroidTypeLocation[]
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  asteroids AsteroidTypeLocation[]
}

model ItemAsteroidType {
  itemId         String
  asteroidTypeId String

  item         Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  asteroidType AsteroidType @relation(fields: [asteroidTypeId], references: [id], onDelete: Cascade)

  @@id([itemId, asteroidTypeId])
}

model AsteroidTypeLocation {
  asteroidTypeId String
  locationId     String

  asteroidType AsteroidType @relation(fields: [asteroidTypeId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([asteroidTypeId, locationId])
}

model Pack {
  id          String     @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PackItem[]
}

model PackItem {
  id       String @id @default(cuid())
  packId   String
  itemId   String
  quantity Int

  pack Pack @relation(fields: [packId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([packId, itemId])
}

model Factory {
  id        String   @id @default(cuid())
  name      String   @unique
  typeId    Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Refinery {
  id        String   @id @default(cuid())
  name      String   @unique
  typeId    Int?     @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
